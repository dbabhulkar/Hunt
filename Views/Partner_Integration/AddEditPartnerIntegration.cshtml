    function AddAPIRow() {
        var APIName = $("#APIName").val();
        var APIRisk = $("#APIRisk").val();
        var APIRiskScore = $("#APIRiskScore").val();
        var rowCount = $('.trAPI').length + 1;

        $('#tblAPIbody tr').each(function (e) {
            if ($(this).find("td .APIName").val() == $("#APIName").val()) {
                debugger;
                alert("Duplicate API not allowed to add !!");

                $("#APIName").val("");
                $("#APIRisk").val("");
                $("#APIRiskScore").val("");
                return false;
            }
        });

        if ($("#APIName").val() != null && $("#APIName").val() != "") {
            if (APIRisk != "" && APIRiskScore != "") {
                var newTR = '<tr class="trAPI">' +
                    '<td><input type="text" name="APIName' + rowCount + '" id="APIName' + rowCount + '" class="form-control APIName" readonly style="background-color: lightgray;" value="' + APIName + '"/></td>' +
                    '<td><input type="text" name="APIRisk' + rowCount + '" id="APIRisk' + rowCount + '" class="form-control APIRisk" readonly style="background-color: lightgray;" value="' + APIRisk + '"/></td>' +
                    '<td><input type="text" name="APIRiskScore' + rowCount + '" id="APIRiskScore' + rowCount + '" class="form-control APIRiskScore" readonly style="background-color: lightgray;" value="' + APIRiskScore + '"/></td>' +
                    '<td><button class="close-btn" type="button" onclick="removeAPIRow(this)"><i class="bx bx-x-circle"style="color: red;"></i></button></td>' +
                    "</tr>";

                $('.TableAddDeleteNew tbody').append(newTR);

                $("#APIName").val("");
                $("#APIRisk").val("");
                $("#APIRiskScore").val("");
            }
            else {
                alert("API Risk and API Risk Score Required to Add API !!");
            }
            CalculateAPIRisk();
        }
    }

    function removeAPIRow(button) {
        $(button).closest('tr').remove();

        CalculateAPIRisk();
    }


