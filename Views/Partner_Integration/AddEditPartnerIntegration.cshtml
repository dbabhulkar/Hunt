<script src="~/js/jquery.min.js"></script>
<script>
    var current_fs, next_fs, previous_fs;//fieldsets
    var opacity;
    var current = 1;
    var steps = $("fieldset").length;
    var lstPartnerEntityType = [];
    $(document).ready(function () {
        //$("#PartnerTPRMAssesmetApplicability").val("Partial");

        var currentDate = new Date();
        currentDate.setHours(0, 0, 0, 0);

        $("#TentativeGoLiveDate").on("change", function () {
            var selectedDate = $(this).val();
            if (selectedDate) {
                var selectedDateObject = new Date(selectedDate);
                selectedDateObject.setHours(0, 0, 0, 0);
                if (selectedDateObject < currentDate) {
                    $(this).val("");
                    $("#TentativeGoLiveDate_Span").text("Past date not allowed.");
                    $("#TentativeGoLiveDate_Span").show(); // Show the error message span
                } else {
                    $("#TentativeGoLiveDate_Span").text("");
                    $("#TentativeGoLiveDate_Span").hide();
                }
            }
        });

        $("#redirectbutton").click(function () {
            debugger;
            if ($("#PartnerName").val() == '') {
                alert("Please enter Partner Name");
                return false;
            }
            //else if ($("#projectDescription").val() == '') {
            //    alert("Please enter Project Description");
            //    return false;
            //}
            else if ($("#TentativeGoLiveDate").val() == '') {
                alert("Please enter Tentative Go Live Date");
                return false;
            }
            else if ($("#ddlPartnerType").val() == '') {
                alert("Please enter Partner Type");
                return false;
            }
            else if ($("#PartnerEntityType").val() == '') {
                alert("Please enter Partner Entity Type");
                return false;
            }
            else if ($("#PartnerRiskScore").val() == '') {
                alert("Please enter Partner Risk Score");
                return false;
            }
            else if ($("#PartnerRisk").val() == '') {
                alert("Please enter Partner Risk");
                return false;
            }
            else if ($("#AttachedJourneyDocuments").val() == '') {
                alert("Please Attach Journey Documents");
                return false;
            }
            else if ($("#APIRiskAssessment").val() == '') {
                alert("Please Attach Partner Risk Assessment Sheet");
                return false;
            }
            else if ($("#tblAPIbody tr").length == 0) {
                alert("Please Add API !!");
                return false;
            }
            else {
                debugger;
                current_fs = $(this).parent();
                next_fs = $(this).parent().next();

                //Add Class Active
                $("#progressbar li").eq($("fieldset").index(next_fs)).addClass("active");

                //show the next fieldset
                next_fs.show();
                //hide the current fieldset with style
                current_fs.animate({ opacity: 0 }, {
                    step: function (now) {
                        // for making fielset appear animation
                        opacity = 1 - now;

                        current_fs.css({
                            'display': 'none',
                            'position': 'relative'
                        });
                        next_fs.css({ 'opacity': opacity });
                    },
                    duration: 500
                });
                setProgressBarNEw(++current);
                BindPartnerCaseApprovalMetrix();
                $("#PartnerRiskClassification").text($("#PartnerRisk").val());
                CalculateAPIRisk();
            }
        });

        $("#btnSubmit").click(function (e) {
            e.preventDefault();
            debugger;
            if ($("#ddlHOPP_FH option").length > 1 && $("#ddlHOPP_FH").val() == "") {
                alert("Please Select Functional Head of Product processor!!");
                return false;
            }
            if ($("#ddlHOPP_VH option").length > 1 && $("#ddlHOPP_VH").val() == "") {
                alert("Please Select Vertical Head of Product processor!!");
                return false;

            }
            if ($("#ddlHOPP_GH option").length > 1 && $("#ddlHOPP_GH").val() == "") {
                alert("Please Select Group Head of Product processor!!");
                return false;
            }

            if ($("#ddlHOB_FH option").length > 1 && $("#ddlHOB_FH").val() == "") {
                alert("Please Select Business Functional Head !!");
                return false;
            }
            if ($("#ddlHOB_VH option").length > 1 && $("#ddlHOB_VH").val() == "") {
                alert("Please Select Business Vertical Head !!");
                return false;
            }
            if ($("#ddlHOB_GH option").length > 1 && $("#ddlHOB_GH").val() == "") {
                alert("Please Select Business Group Head !!");
                return false;
            }

            if ($("#ddlHODB_FH option").length > 1 && $("#ddlHODB_FH").val() == "") {
                alert("Please Select Functional Head of Digital Banking!!");
                return false;
            }
            if ($("#ddlHODB_VH option").length > 1 && $("#ddlHODB_VH").val() == "") {
                alert("Please Select Vertical Head of Digital Banking!!");
                return false;
