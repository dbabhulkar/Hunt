                $("#PartnerEntityType").empty();
                $("#PartnerEntityType").append($("<option></option>").val("").html("-- Select --"));
                if (objData.length > 0) {
                    $.each(objData, function (data, value) {
                        $("#PartnerEntityType").append($("<option></option>").val(value.PartnerEntityType).html(value.PartnerEntityType));
                    });
                }
            }
        });
    }

