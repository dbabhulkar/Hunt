@model API_HUNT.Models.PartnerOnboarding
@inject IHttpContextAccessor Accessor
@using Microsoft.AspNetCore.Http
@using Newtonsoft.Json
@{
    ViewData["Title"] = "ViewPartnerIntegration";
    Layout = "~/Views/Shared/_Layout.cshtml";
}
<style>
    /* Adjust the modal appearance */
    .modal-content {
        background-color: #ffffff; /* Set background color to white */
        box-shadow: 0px 0px 10px rgba(0, 0, 0, 0.5); /* Add a subtle shadow */
    }

    /* Center the modal */
    .modal-dialog {
        margin: auto;
    }

    .action-button,
    .action-button-previous {
        margin-right: 10px; /* Adjust the value as needed */
    }
</style>

@using (Html.BeginForm("", "", FormMethod.Post, new { @enctype = "multipart/form-data" }))
{
    <div class="container-fluid">
        <div class="card">
            <div class="card-body">
                <div class="row form-group">
                    <div class="col-md-12 addnew-popup-heading" style="border-bottom: 1px solid #f5eeee;">
                        <h4>Edit Partner</h4>
                        <a href="/Partner_Integration/ListofPartnerIntegration/" class="close-btn" style="font-size: 15px; font-weight: 600;"><i class="bx bx-left-arrow-circle" style="vertical-align:middle;"></i> Back</a>
                    </div>
                </div>
                <div class="row form-group">
                    <div id="msform">
                        <ul id="progressbar">
                            <li class="active" id="onboarding"><strong>Partner Integration</strong></li>
                            <li id="approval"><strong>Sent For Approval</strong></li>
                        </ul>
                        <fieldset>
                            <section class="background">
                                <b>Partner Details:</b>
                                <div class="row form-group">
                                    <div class="col-md-4">
                                        @Html.LabelFor(a => a.PartnerName, new { @class = "label-control" })&nbsp;&nbsp;<span style="font-weight:bold;color:red;font-size: 12px;">*</span>
                                        @Html.TextBoxFor(a => a.PartnerName, new { @class = "form-control", @readonly = "readonly", @style = "background-color: lightgray;" })
                                        @Html.ValidationMessageFor(a => a.PartnerName, "", new { @class = "text-danger" })
                                        @Html.HiddenFor(a => a.CaseID, new { @class = "form-control" })
                                    </div>
                                    <div class="col-md-4">
                                        @Html.LabelFor(a => a.projectDescription, new { @class = "label-control" })&nbsp;&nbsp;@*<span style="font-weight:bold;color:red;font-size: 12px;">*</span>*@
                                        @Html.TextBoxFor(a => a.projectDescription, new { @class = "form-control", @readonly = "readonly", @style = "background-color: lightgray;" })
                                        @Html.ValidationMessageFor(a => a.projectDescription, "", new { @class = "text-danger" })
                                    </div>
                                    <div class="col-md-4">
                                        @Html.LabelFor(a => a.PartnerType, new { @class = "label-control" })&nbsp;&nbsp;<span style="font-weight:bold;color:red;font-size: 12px;">*</span>
                                        @Html.DropDownListFor(a => a.PartnerType, (List<SelectListItem>
                                                 )ViewBag.Listofproducts, "--Select--", new { @class = "form-control ", @id = "ddlPartnerType", @readonly = "readonly", @style = "background-color: lightgray;" })
                                        @Html.ValidationMessageFor(a => a.PartnerType, "", new { @class = "text-danger" })
                                    </div>
                                    <div class="col-md-4">
                                        @Html.LabelFor(a => a.PartnerSubType, new { @class = "label-control" })&nbsp;&nbsp;<span style="font-weight:bold;color:red;font-size: 12px;">*</span>
                                        @Html.DropDownListFor(a => a.PartnerSubType, (List<SelectListItem>
                                                 )ViewBag.Listofproducts, "--Select--", new { @class = "form-control d-none", @id = "ddlPartnerType", @readonly = "readonly", @style = "background-color: lightgray;" })
                                        @Html.TextBoxFor(a => a.PartnerSubType, new { @class = "form-control", @readonly = "readonly", @style = "background-color: lightgray;" })
                                        @Html.ValidationMessageFor(a => a.PartnerSubType, "", new { @class = "text-danger" })
                                    </div>
                                    <div class="col-md-4">
                                        @Html.LabelFor(a => a.PartnerEntityType, new { @class = "label-control" })&nbsp;&nbsp;<span style="font-weight:bold;color:red;font-size: 12px;">*</span>
