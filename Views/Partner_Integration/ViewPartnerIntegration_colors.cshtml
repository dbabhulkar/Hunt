    function setStatusColor(status, textboxId) {
        var textbox = $('#' + textboxId);

        switch (status) {
            case 'Approved':
                textbox.prop('readonly', true);
                textbox.css('background-color', 'lightgray');
                textbox.css('background-color', '#66ff99'); // Light green
                break;
            case 'Feedback to User':
                textbox.prop('readonly', true);
                textbox.css('background-color', 'lightgray');
                textbox.css('background-color', '#008000'); // Blue
                break;
            case 'Reject':
                textbox.prop('readonly', true);
                textbox.css('background-color', 'lightgray');
                textbox.css('background-color', '#ff6666'); // Red
                break;
            default:
                // Set default color or handle other statuses if needed
                textbox.prop('readonly', false);
                textbox.css('background-color', '');
                break;
        }
    }
