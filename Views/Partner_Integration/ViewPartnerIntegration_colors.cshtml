                                                                <a href="@Url.Action("DownloadFile", "PartnerApproval" , new { fileName=Model.CaseID + "_OtherDocument" })" target="_blank">
                                                                    <i class="bx bx-cloud-download" style="font-size: 20px;margin-top:2px;"></i> <!-- Download icon -->
                                                                </a>
                                                                <span>|</span>
                                                                <a href="#" onclick="openFileInPopup('@Url.Action("DisplayFile", "PartnerApproval" , new { fileName=Model.CaseID + "_OtherDocument" })')">
                                                                    <i class="bx bxs-show" style="font-size:20px;"></i> <!-- Display icon -->
                                                                </a>
                                                            }
                                                            else
                                                            {
                                                                <span class="text-danger">Not Uploaded</span>
                                                            }
                                                        </td>
                                                    </tr>
                                                }
                                            </tbody>

                                        </table>
                                    </div>
                                </section>
                            </div>
                            <input type="button" id="redirectbutton" name="next" class="next action-button btn btn-primary" value="Next" />
                        </fieldset>
