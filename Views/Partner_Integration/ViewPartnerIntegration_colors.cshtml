                                            <thead>
                                                <tr>
                                                    <th>API Name</th>
                                                    <th>API Risk</th>
                                                    <th>API Risk Score</th>
                                                </tr>
                                            </thead>
                                            <tbody id="tblAPIbody" class="d-none">
                                                @foreach (var item in Model.lstApiDetail)
                                                {
                                                    <tr>
                                                        <td>
                                                            @item.APIName
                                                            @Html.HiddenFor(model => item.APIId)
                                                        </td>
                                                        <td class="APIRisk">
                                                            @item.APIRisk
                                                        </td>
                                                        <td>
                                                            @item.APIRiskScore
                                                        </td>
                                                    </tr>
                                                }
                                            </tbody>
                                            <tbody id="tblAPIbody">
                                                @for (var i = 0; i < Model.lstApiDetail.Count; i++)
                                                {
                                                    <tr>
                                                        <td>
                                                            @Model.lstApiDetail[i].APIName
                                                            @Html.HiddenFor(model => Model.lstApiDetail[i].APIId)
                                                        </td>
                                                        <td class="APIRisk">
                                                            @Model.lstApiDetail[i].APIRisk
                                                        </td>
                                                        <td style="width: 120px;">
                                                            @Model.lstApiDetail[i].APIRiskScore
                                                        </td>

                                                        @if (i == Model.lstApiDetail.Count - 1)
                                                        {
                                                            <td style="text-align: left;">
                                                                <!-- Button only in the last iteration -->
                                                                <button id="btnViewAPIRisk" name="btnViewAPIRisk" class="action-button btn btn-primary btn-sm" style="border-radius: 5px; margin-top: 0px; margin-left: 5px; background-color: #3498db; color: #fff; border: none; cursor: pointer; transition: background-color 0.3s ease; font-size: 12px; padding: 8px 15px;" onclick="openFileInPopup('@Url.Action("DisplayFile", "PartnerApproval" , new { fileName=Model.CaseID + "_APIRiskAssessment" })')">VIEW API RISK SCORE</button>
                                                            </td>
                                                        }
                                                        else
                                                        {
                                                            <td></td>
                                                        }
                                                    </tr>
                                                }
                                            </tbody>
                                        </table>
                                        <div class="col-md-4 d-flex justify-content-center d-none">
                                            <input type="button" id="btnViewAPIRisk" name="btnViewAPIRisk" class="action-button btn btn-primary mx-auto" value="VIEW API RISK SCORE"
