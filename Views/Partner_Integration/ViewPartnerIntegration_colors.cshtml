                                        </div>
                                    </div>
                                </div>
                            </section>
                            <div class="col-md-12">
                                <section class="background">
                                    <b>Uploaded Files : </b>
                                    <div class="row form-group">
                                        <table class="table table-hover table-striped" id="FileSection_6">
                                            <thead>
                                                <tr>
                                                    <th>Document Type</th>
                                                    <th>Action</th>
                                                </tr>
                                            </thead>
                                            <tbody class="table-border-bottom-0">
                                                @if (!string.IsNullOrEmpty(Model.AttachedJourneyDocuments))
                                                {
                                                    <tr>
                                                        <td>Attached Journey Documents</td>
                                                        <td>
                                                            @if (!string.IsNullOrEmpty(Model.CaseID))
                                                            {
                                                                <a href="@Url.Action("DownloadFile", "PartnerApproval" , new { fileName=Model.CaseID + "_AttachedJourneyDocuments" })" target="_blank">
                                                                    <i class="bx bx-cloud-download" style="font-size: 20px;margin-top:2px;"></i> <!-- Download icon -->
                                                                </a>
                                                                <span>|</span>
                                                                <a href="#" onclick="openFileInPopup('@Url.Action("DisplayFile", "PartnerApproval" , new { fileName=Model.CaseID + "_AttachedJourneyDocuments" })')">
                                                                    <i class="bx bxs-show" style="font-size:20px;"></i> <!-- Display icon -->
                                                                </a>
                                                            }
                                                            else
                                                            {
                                                                <span class="text-danger">Not Uploaded</span>
                                                            }
                                                        </td>
                                                    </tr>
                                                }
                                                @if (!string.IsNullOrEmpty(Model.APIRiskAssessmentSheet))
                                                {
                                                    <tr>
                                                        <td>Partner Risk Assessment Sheet</td>
                                                        <td>
                                                            @if (!string.IsNullOrEmpty(Model.CaseID))
                                                            {
                                                                <a href="@Url.Action("DownloadFile", "PartnerApproval" , new { fileName=Model.CaseID + "_APIRiskAssessment" })" target="_blank">
                                                                    <i class="bx bx-cloud-download" style="font-size: 20px;margin-top:2px;"></i> <!-- Download icon -->
                                                                </a>
                                                                <span>|</span>
                                                                <a href="#" onclick="openFileInPopup('@Url.Action("DisplayFile", "PartnerApproval" , new { fileName=Model.CaseID + "_APIRiskAssessment" })')">
                                                                    <i class="bx bxs-show" style="font-size:20px;"></i> <!-- Display icon -->
                                                                </a>
                                                            }
                                                            else
                                                            {
                                                                <span class="text-danger">Not Uploaded</span>
                                                            }
                                                        </td>
                                                    </tr>
                                                }
                                                @if (!string.IsNullOrEmpty(Model.AttachedClientProfileSheet))
                                                {
                                                    <tr>
                                                        <td>Attached Client Profile Sheet</td>
                                                        <td>
                                                            @if (!string.IsNullOrEmpty(Model.CaseID))
                                                            {
                                                                <a href="@Url.Action("DownloadFile", "PartnerApproval" , new { fileName=Model.CaseID + "_AttachedClientProfileSheet" })" target="_blank">
                                                                    <i class="bx bx-cloud-download" style="font-size: 20px;margin-top:2px;"></i> <!-- Download icon -->
                                                                </a>
                                                                <span>|</span>
                                                                <a href="#" onclick="openFileInPopup('@Url.Action("DisplayFile", "PartnerApproval" , new { fileName=Model.CaseID + "_AttachedClientProfileSheet" })')">
                                                                    <i class="bx bxs-show" style="font-size:20px;"></i> <!-- Display icon -->
                                                                </a>
                                                            }
                                                            else
                                                            {
                                                                <span class="text-danger">Not Uploaded</span>
                                                            }
                                                        </td>
                                                    </tr>
                                                }
                                                @if (!string.IsNullOrEmpty(Model.OtherDocument))
                                                {
                                                    <tr>
                                                        <td>Other Document</td>
                                                        <td>
                                                            @if (!string.IsNullOrEmpty(Model.CaseID))
