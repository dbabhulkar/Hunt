                        <fieldset>
                            <div class="row form-group">
                                <div>
                                    <label class="label-control" style="font-weight: 600;">Approval Matrix For Case ID - </label>
                                    <label id="CaseID" name="CaseID">@Model.CaseID</label>
                                </div>
                                <div>
                                    <label class="label-control" style="font-weight: 600;">Partner Name- </label>
                                    <label id="CaseID" name="CaseID">@Model.PartnerName</label>
                                </div>
                                <div>
                                    <label class="label-control" style="font-weight: 600;">API Risk - </label>
                                    <label name="APIRiskClassification" id="APIRiskClassification">@Model.APIRisk</label>
                                </div>
                                <div>
                                    <label class="label-control" style="font-weight: 600;">Partner Risk - </label>
                                    <label name="PartnerRiskClassification" id="PartnerRiskClassification">@Model.PartnerRisk</label>
                                </div>
                            </div>
                            <div class="row form-group">
                                <ul id="progressbar">
                                    @if (Accessor.HttpContext.Session.GetString("Role") == "USER")
                                    {
                                        @foreach (var item in Model.lstDepartmentStatus)
                                        {
                                            if (item.Department == "HOPP" && item.ApprovalStatus == "Approved")
                                            {
                                                <li id="approval" class="active"><strong>Product Processor</strong></li>
                                            }
                                            if (item.Department == "HOPP" && item.ApprovalStatus == "Pending")
                                            {
                                                <li id="approval"><strong>Product Processor</strong></li>
                                            }

                                            if (item.Department == "HOB" && item.ApprovalStatus == "Approved")
                                            {
                                                <li id="approval" class="active"><strong>Business</strong></li>
                                            }
                                            if (item.Department == "HOB" && item.ApprovalStatus == "Pending")
                                            {
                                                <li id="approval"><strong>Business</strong></li>
                                            }

                                            if (item.Department == "HODB" && item.ApprovalStatus == "Approved")
                                            {
                                                <li id="approval" class="active"><strong>Digital Banking</strong></li>
                                            }
                                            if (item.Department == "HODB" && item.ApprovalStatus == "Pending")
                                            {
                                                <li id="approval"><strong>Digital Banking</strong></li>
                                            }

                                            if (item.Department == "HOISG" && item.ApprovalStatus == "Approved")
                                            {
                                                <li id="approval" class="active"><strong>ISG</strong></li>
                                            }
                                            if (item.Department == "HOISG" && item.ApprovalStatus == "Pending")
                                            {
                                                <li id="approval"><strong>ISG</strong></li>
                                            }

