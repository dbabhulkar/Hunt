                                        <input type="button" id="btnViewPartnerRisk" name="btnViewPartnerRisk"
                                               style="margin-top: 22px;margin-right: 175px;font-size: 12px; padding: 8px 16px; border-radius: 5px; background-color: #3498db; color: #fff; border: none; cursor: pointer; transition: background-color 0.3s ease;"
                                               value="View Partner Risk Score"
                                               onclick="openFileInPopup('@Url.Action("DisplayFile", "PartnerApproval" , new { fileName=Model.CaseID + "_APIRiskAssessment" })')" />
                                    </div>
                                </div>
                            </section>
                            <section class="background">
                                <div id="attributes">
                                    <div class="attr row form-group">
                                        <table id="tbladdAPI" name="tbladdAPI" class="TableAddDeleteNew table table-hover table-striped">
