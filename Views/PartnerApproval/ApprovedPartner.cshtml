    function SaveAddPartnerApproval(st) {
        var partnerApproval = {};

        if ($('#CurrentDepartment').val() == "HOPP") {
            if ($('#CurrentApproverUserID').val() == $('#HOPP_FH').val()) {
                partnerApproval.AssignTo = $('#HOPP_VH').val();
                partnerApproval.AssignToLevel = "VH";
                partnerApproval.AssignToDept = "HOPP";
            }
            if ($('#CurrentApproverUserID').val() == $('#HOPP_VH').val()) {
                partnerApproval.AssignTo = $('#HOPP_GH').val();
                partnerApproval.AssignToLevel = "GH";
                partnerApproval.AssignToDept = "HOPP";
            }
        }
        if ($('#CurrentDepartment').val() == "HOB") {
            if ($('#CurrentApproverUserID').val() == $('#HOB_FH').val()) {
                partnerApproval.AssignTo = $('#HOB_VH').val();
                partnerApproval.AssignToLevel = "VH";
                partnerApproval.AssignToDept = "HOB";
            }
            if ($('#CurrentApproverUserID').val() == $('#HOB_VH').val()) {
                partnerApproval.AssignTo = $('#HOB_GH').val();
                partnerApproval.AssignToLevel = "GH";
                partnerApproval.AssignToDept = "HOB";
            }
        }
        if ($('#CurrentDepartment').val() == "HODB") {
            if ($('#CurrentApproverUserID').val() == $('#HODB_FH').val()) {
                partnerApproval.AssignTo = $('#HODB_VH').val();
                partnerApproval.AssignToLevel = "VH";
                partnerApproval.AssignToDept = "HODB";
            }
            if ($('#CurrentApproverUserID').val() == $('#HODB_VH').val()) {
                partnerApproval.AssignTo = $('#HODB_GH').val();
                partnerApproval.AssignToLevel = "GH";
                partnerApproval.AssignToDept = "HODB";
            }
        }
        if ($('#CurrentDepartment').val() == "HOISG") {
            if ($('#CurrentApproverUserID').val() == $('#HOISG_FH').val()) {
                partnerApproval.AssignTo = $('#HOISG_VH').val();
                partnerApproval.AssignToLevel = "VH";
