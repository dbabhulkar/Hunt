    function openFileInPopup(url) {
        debugger;
        try {
            if (url) {
                // Calculate the center position for the new window
                var width = 800; // Specify your desired width
                var height = 600; // Specify your desired height
                var left = (window.screen.width - width) / 2;
                var top = (window.screen.height - height) / 2;

                // Create a new window or modal dialog for displaying the file
                var newWindow = window.open(url, '_blank', 'width=' + width + ', height=' + height + ', left=' + left + ', top=' + top);

                if (newWindow) {
                    newWindow.focus();
                } else {
                    // Handle the case where the new window couldn't be opened
                    alert("Failed to open the file. Please check if the file exists.");
                }
            } else {
                // Display a message when no file is uploaded
                alert("No file uploaded for this.");
            }
        } catch (error) {
            // Handle any unexpected errors
            alert("An error occurred: " + error.message);
        }
    }
    function CalculateAPIRisk() {
        var apiRiskCounts = {};
        $('#tblAPIbody .APIRisk').each(function () {
            var apiRisk = $(this).text().trim();

            if (apiRisk in apiRiskCounts) {
                apiRiskCounts[apiRisk]++;
            } else {
                apiRiskCounts[apiRisk] = 1;
            }
        });
        var maxApiRisk = null;
        var maxCount = 0;
        for (var apiRisk in apiRiskCounts) {
            if (apiRisk === "High") {
                maxApiRisk = "High";
                break;
            }
            else if (apiRisk === "Medium") {
                maxApiRisk = "Medium";
                break;
            }
            else {
                if (apiRiskCounts[apiRisk] > maxCount) {
                    maxCount = apiRiskCounts[apiRisk];
                    maxApiRisk = apiRisk;
                }
            }
        }

        // Set the maxApiRisk value to the PartnerRisk textbox
        $('#APIRiskClassification').text(maxApiRisk);
    }
    function GetMstPartnerType() {
        debugger;
        $.ajax({
            url: "@Url.Action("GetMstPartnerType", "PartnerOnboarding")",
            data: { PartnerType: $("#ddlPartnerType").val() },
            dataType: "json",
            type: "GET",
            error: function () {
                alert(" An error occurred.");
            },
            success: function (data) {
                objData = $.parseJSON(data);

                lstPartnerEntityType = objData;
                var PartnerEntityType = objData.filter(obj => obj.PartnerType == $("#PartnerType").text());
                $("#PartnerEntityType").empty();
                $("#PartnerEntityType").append($("<option></option>").val("").html("-- Select --"));
                if (objData.length > 0) {
                    $.each(objData, function (data, value) {
                        $("#PartnerEntityType").append($("<option></option>").val(value.PartnerEntityType).html(value.PartnerEntityType));
                    });
                }
            }
        });
    }

