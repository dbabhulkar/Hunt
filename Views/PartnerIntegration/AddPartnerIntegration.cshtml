                                            @Html.HiddenFor(a => a.HOITDRM_GH_Status, new { @class = "form-control" })
                                        </div>
                                    </div>
                                </section>
                                @if (Accessor.HttpContext.Session.GetString("Role") == "USER")
                                {
                                    <input type="button" name="btnSubmit" class="action-button" value="Submit" id="btnSubmit" />
                                    <input type="button" name="previous" class="previous action-button-previous" value="Previous" />
                                }
                                else
                                {
                                    <input type="button" name="previous" class="previous action-button-previous" value="Previous" />
                                    <br />

                                }
                            </fieldset>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </form>
}
