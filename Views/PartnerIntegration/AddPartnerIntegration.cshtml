    function openFileInPopup(url) {
        debugger;
        try {
            if (url) {
                var width = 800;
                var height = 600;
                var left = (window.screen.width - width) / 2;
                var top = (window.screen.height - height) / 2;

                fetch(url)
                    .then(function (response) {
                        if (!response.ok) {
                            if (response.status == 404) {
                                alert("No File Uploaded For This");
                            }
                            else {
                                alert("HTTP Error: " + response.status);
                            }
                        } else {
                            var newWindow = window.open(url, '_blank', 'width=' + width + ', height=' + height + ', left=' + left + ', top=' + top);

                            if (newWindow) {
                                newWindow.focus();
                            } else {
                                alert("Failed to open the file. Please check if the file exists.");
                            }
                        }
                    })
                    .catch(function (error) {
                        alert("An error occurred: " + error.message);
                    });
            } else {
                alert("No file uploaded for this.");
            }
        } catch (error) {
            alert("An error occurred: " + error.message);
        }
    }

    function AddAPIRow() {
        var APIName = $("#APIName").val();
        var APIRisk = $("#APIRisk").val();
        var APIRiskScore = $("#APIRiskScore").val();
        var APIId = $("#APIId").val();
        var rowCount = $('.trAPI').length + 1;

        $('#tblAPIbody tr').each(function (e) {
            if ($(this).find("td .APIName").val() == $("#APIName").val()) {
                debugger;
                alert("Duplicate API not allowed to add !!");

                $("#APIName").val("");
                $("#APIRisk").val("");
                $("#APIRiskScore").val("");
                return false;
            }
        });

        if ($("#APIName").val() != null && $("#APIName").val() != "") {
            if (APIRisk != "" && APIRiskScore != "") {
                var newTR = '<tr class="trAPI">' +
                    '<td><input type="text" name="APIName_' + rowCount + '" id="APIName_' + rowCount + '" class="form-control APIName" readonly style="background-color: lightgray;" value="' + APIName + '"/>' +
                    '<input type="hidden" name="APIId_' + rowCount + '" id="APIId_' + rowCount + '" class="APIId" value="' + APIId + '"/></td>' + // Added hidden input for APIId
                    '</td>' +
                    '<td class="APIRisktd"><input type="text" name="APIRisk_' + rowCount + '" id="APIRisk_' + rowCount + '" class="form-control APIRisk" readonly style="background-color: lightgray;" value="' + APIRisk + '"/></td>' +
                    '<td><input type="text" name="APIRiskScore_' + rowCount + '" id="APIRiskScore_' + rowCount + '" class="form-control APIRiskScore" readonly style="background-color: lightgray;" value="' + APIRiskScore + '"/></td>' +
                    '<td><button class="close-btn" type="button" onclick="removeAPIRow(this)"><i class="bx bx-x-circle"style="color: red;"></i></button></td>' +
                    "</tr>";
                $('.TableAddDeleteNew tbody').append(newTR);

                $("#APIName").val("");
                $("#APIId").val("");
                $("#APIRisk").val("");
                $("#APIRiskScore").val("");
            } else {
                alert("API Risk and API Risk Score Required to Add API !!");
            }
            CalculateAPIRisk();
        }
    }

    function removeAPIRow(button) {
        $(button).closest('tr').remove();
        CalculateAPIRisk();
    }

    function CalculateAPIRisk() {
        var apiRiskCounts = {};
        $('#tblAPIbody .APIRisktd').each(function () {
            var apiRisk = "";
            $(this).find('input').each(function () {
                apiRisk = $(this).val();
            });

            if (apiRisk in apiRiskCounts) {
                apiRiskCounts[apiRisk]++;
            } else {
                apiRiskCounts[apiRisk] = 1;
            }
        });
        var maxApiRisk = null;
        var maxCount = 0;
        for (var apiRisk in apiRiskCounts) {
            if (apiRisk === "High") {
                maxApiRisk = "High";
                break;
            }
            else if (apiRisk === "Medium") {
                maxApiRisk = "Medium";
                break;
            }
            else {
                if (apiRiskCounts[apiRisk] > maxCount) {
                    maxCount = apiRiskCounts[apiRisk];
                    maxApiRisk = apiRisk;
                }
            }
        }
        // Set the maxApiRisk value to the PartnerRisk textbox
        $('#APIRiskClassification').text(maxApiRisk);
    }

