    function SavePartnerIntegration() {
        var objPartnerOnboarding = {};
        objPartnerOnboarding.PartnerID = $('#PartnerID').val();
        objPartnerOnboarding.CaseID = $('#CaseID').val();
        objPartnerOnboarding.PartnerRiskClassification = $('#PartnerRiskClassification').text();
        objPartnerOnboarding.APIRiskClassification = $('#APIRiskClassification').text();
        var lstApiDetail = [];
        $('#tblAPIbody tr').each(function (e) {
            var obj = {};
            debugger;
            obj.APIName = $(this).find("td .APIName").val();
            obj.APIId = $(this).find("td .APIId").val();
            obj.APIRisk = $(this).find("td .APIRisk").val();
            obj.APIRiskScore = $(this).find("td .APIRiskScore").val();
            lstApiDetail.push(obj);
        });
        objPartnerOnboarding.lstApiDetail = lstApiDetail;
        objPartnerOnboarding.HOPP_FH = $("#ddlHOPP_FH").val();
        objPartnerOnboarding.HOPP_VH = $("#ddlHOPP_VH").val();
        objPartnerOnboarding.HOPP_GH = $("#ddlHOPP_GH").val();
        objPartnerOnboarding.HOB_FH = $("#ddlHOB_FH").val();
        objPartnerOnboarding.HOB_VH = $("#ddlHOB_VH").val();
        objPartnerOnboarding.HOB_GH = $("#ddlHOB_GH").val();
        objPartnerOnboarding.HODB_FH = $("#ddlHODB_FH").val();
        objPartnerOnboarding.HODB_VH = $("#ddlHODB_VH").val();
        objPartnerOnboarding.HODB_GH = $("#ddlHODB_GH").val();
        objPartnerOnboarding.HOISG_FH = $("#ddlHOISG_FH").val();
        objPartnerOnboarding.HOISG_VH = $("#ddlHOISG_VH").val();
        objPartnerOnboarding.HOISG_GH = $("#ddlHOISG_GH").val();
        objPartnerOnboarding.HOITDRM_FH = $("#ddlHOITDRM_FH").val();
        objPartnerOnboarding.HOITDRM_VH = $("#ddlHOITDRM_VH").val();
        objPartnerOnboarding.HOITDRM_GH = $("#ddlHOITDRM_GH").val();
        objPartnerOnboarding.Action = $("#Action").val();

        var formData = new FormData();
        formData.append("AttachedJourneyDocuments", $("#AttachedJourneyDocuments")[0].files[0]);
        formData.append("OtherDocument", $("#OtherDocument")[0].files[0]);
        formData.append("objPartnerOnboarding", JSON.stringify(objPartnerOnboarding));
        formData.append("jsonPartnerOnboarding", JSON.stringify(objPartnerOnboarding));
        formData.append("next", "Request For Approval");
        try {
            $.ajax({
                type: "POST",
                url: '/PartnerIntegration/SavePartnerIntegration',
                data: formData,
                contentType: false, // Important to prevent jQuery from processing the data
                processData: false, // Important to prevent jQuery from processing the data
                dataType: 'json',
                success: function (response) {
                    if (response != null) {
                        debugger;
                        alert("Data Edited Successfully !!");
                        window.location.href = '/PartnerIntegration/ListofPartner';
                    }
                    else {
                        toastr.error("Information not available against this Application.");
                    }
                    window.location.href = '/PartnerIntegration/ListofPartner';
                },
                error: function (jqXHR, textStatus, errorThrown) {
                    //console.error("AJAX Error:", textStatus, errorThrown);
                    // You can handle the error here, for example, show an alert or log it.
                },
                complete: function () {
                    // This will be called after success or error
                    window.location.href = '/PartnerIntegration/ListofPartner';
                }
            });
        } catch (error) {
            // Handle any unexpected errors
            alert("An error occurred: " + error.message);
        }
    }
</script>