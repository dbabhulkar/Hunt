                PartnerRiskClassification: $("#PartnerRiskClassification").text(),
                APIRiskClassification: $("#APIRiskClassification").text(),
                ApproverType: "Product processor",
                ApproverLevel: "VH"
            },
            dataType: "json",
            type: "GET",
            error: function () {
                alert(" An error occurred.");
            },
            success: function (data) {
                debugger;
                $(".DropDownProject option[value!='']").remove();
                objData = $.parseJSON(data);

                /*Bind OPtion ddlProdProcessorFH */
                var ddlHOPP_FH = objData.filter(obj => obj.PartnerRiskClassification == $("#PartnerRiskClassification").text() && obj.APIRiskClassification == $("#APIRiskClassification").text() && obj.ApproverType == "Product processor" && obj.ApproverLevel == "FH")
                if (ddlHOPP_FH.length > 0) {
                    $.each(ddlHOPP_FH, function (data, value) {
                        $("#ddlHOPP_FH").append($("<option></option>").val(value.ApproverUserID).html(value.ApproverUserID + ' - ' + value.ApproverName));
