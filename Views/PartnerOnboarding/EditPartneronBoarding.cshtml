@using Microsoft.AspNetCore.Http
@model API_HUNT.Models.PartnerOnboardingNew

@inject IHttpContextAccessor Accessor
@{
    ViewData["Title"] = "EditPartneronBoarding";
    Layout = "~/Views/Shared/_Layout.cshtml";
}
@using (Html.BeginForm("SaveAddPartneronBoarding", "PartnerOnboarding", FormMethod.Post, new { @enctype = "multipart/form-data" }))
{
    <form id="uploadForm" action="/PartnerOnboarding/ListofPartner" method="post" enctype="multipart/form-data">
        <div class="container-fluid">
            <div class="card">
                <div class="card-body">
                    <div class="row form-group">
