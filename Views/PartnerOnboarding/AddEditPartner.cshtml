<script src="~/js/jquery.min.js"></script>
<script>
    $(document).ready(function () {
        $('.modal-link').click(function () {
            $('.modal').show();
            $('.modal-bg').show();
        });
        $('.modal .close').click(function () {
            $('.modal').hide();
            $('.modal-bg').hide();
        })

        $("#BtnPartnerRiskHigh").click(function () {
            $("#txtPartnerRisk").val("High");
        });
        $("#BtnPartnerRiskMedium").click(function () {
            $("#txtPartnerRisk").val("Medium");
        });
        $("#BtnPartnerRiskLow").click(function () {
            $("#txtPartnerRisk").val("Low");
        });

        $("#BtnPartnerEntityTypeGov").click(function () {
            $("#txtPartnerEntityType").val("Government");
        });
        $("#BtnPartnerEntityTypeNonGov").click(function () {
            $("#txtPartnerEntityType").val("Non-Government");
        });

        $("#redirectbutton").click(function () {
            BindPartnerCaseApprovalMetrix();
        });
    });

    function BindPartnerCaseApprovalMetrix() {
        debugger;
        $.ajax({
            url: "@Url.Action("PartnerCaseApprovalMetrix", "PartnerOnboarding")",
            data: {
                PartnerRiskClassification: $("#PartnerRiskClassification").text(),
                APIRiskClassification: $("#APIRiskClassification").text(),
                ApproverType: "Product processor",
                ApproverLevel: "VH"
            },
            dataType: "json",
            type: "GET",
            error: function () {
                alert(" An error occurred.");
            },
            success: function (data) {
                objData = $.parseJSON(data);

                /*Bind OPtion ddlProdProcessorFH */
                var ddlProdProcessorFH = objData.filter(obj => obj.PartnerRiskClassification == $("#PartnerRiskClassification").text() && obj.APIRiskClassification == $("#APIRiskClassification").text() && obj.ApproverType == "Product processor" && obj.ApproverLevel == "FH")
                if (ddlProdProcessorFH.length > 0) {
                    $.each(ddlProdProcessorFH, function (data, value) {
                        $("#ddlProdProcessorFH").append($("<option></option>").val(value.ApproverUserID).html(value.ApproverName));
                    });
                }
                else {
                    $("#ddlProdProcessorFH").hide();
                }

                /*Bind OPtion ddlProdProcessorVH */
                var ddlProdProcessorVH = objData.filter(obj => obj.PartnerRiskClassification == $("#PartnerRiskClassification").text() && obj.APIRiskClassification == $("#APIRiskClassification").text() && obj.ApproverType == "Product processor" && obj.ApproverLevel == "VH")
                if (ddlProdProcessorVH.length > 0) {
                    $.each(ddlProdProcessorVH, function (data, value) {
                        $("#ddlProdProcessorVH").append($("<option></option>").val(value.ApproverUserID).html(value.ApproverName));
                    });
                }
                else {
                    $("#ddlProdProcessorVH").hide();
                }

                /*Bind OPtion ddlProdProcessorGH */
                var ddlProdProcessorGH = objData.filter(obj => obj.PartnerRiskClassification == $("#PartnerRiskClassification").text() && obj.APIRiskClassification == $("#APIRiskClassification").text() && obj.ApproverType == "Product processor" && obj.ApproverLevel == "GH")
                if (ddlProdProcessorGH.length > 0) {
                    $.each(ddlProdProcessorGH, function (data, value) {
                        $("#ddlProdProcessorGH").append($("<option></option>").val(value.ApproverUserID).html(value.ApproverName));
                    });
                }
                else {
                    $("#ddlProdProcessorGH").hide();
                }

                /*Bind OPtion ddlBusinessFH */
                var ddlBusinessFH = objData.filter(obj => obj.PartnerRiskClassification == $("#PartnerRiskClassification").text() && obj.APIRiskClassification == $("#APIRiskClassification").text() && obj.ApproverType == "Business" && obj.ApproverLevel == "FH")
                if (ddlBusinessFH.length > 0) {
                    $.each(ddlBusinessFH, function (data, value) {
                        $("#ddlBusinessFH").append($("<option></option>").val(value.ApproverUserID).html(value.ApproverName));
                    });
                }
                else {
                    $("#ddlBusinessFH").hide();
                }

                /*Bind OPtion ddlBusinessGH */
                var ddlBusinessGH = objData.filter(obj => obj.PartnerRiskClassification == $("#PartnerRiskClassification").text() && obj.APIRiskClassification == $("#APIRiskClassification").text() && obj.ApproverType == "Business" && obj.ApproverLevel == "GH")
                if (ddlBusinessGH.length > 0) {
                    $.each(ddlBusinessGH, function (data, value) {
                        $("#ddlBusinessGH").append($("<option></option>").val(value.ApproverUserID).html(value.ApproverName));
                    });
                }
                else {
                    $("#ddlBusinessGH").hide();
                }

                /*Bind OPtion ddlBusinessVH */
                var ddlBusinessVH = objData.filter(obj => obj.PartnerRiskClassification == $("#PartnerRiskClassification").text() && obj.APIRiskClassification == $("#APIRiskClassification").text() && obj.ApproverType == "Business" && obj.ApproverLevel == "VH")
                if (ddlBusinessVH.length > 0) {
                    $.each(ddlBusinessVH, function (data, value) {
                        $("#ddlBusinessVH").append($("<option></option>").val(value.ApproverUserID).html(value.ApproverName));
                    });
                }
                else {
                    $("#ddlBusinessVH").hide();
                }

                /*Bind OPtion ddlDigitalBankingGH */
                var ddlDigitalBankingGH = objData.filter(obj => obj.PartnerRiskClassification == $("#PartnerRiskClassification").text() && obj.APIRiskClassification == $("#APIRiskClassification").text() && obj.ApproverType == "Digital Banking" && obj.ApproverLevel == "GH")
                if (ddlDigitalBankingGH.length > 0) {
