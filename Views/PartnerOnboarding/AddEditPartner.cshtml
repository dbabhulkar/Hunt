                    });
                }
                else {
                    $("#ddlDigitalBankingGH").hide();
                }

                /*Bind OPtion ddlDigitalBankingFH */
                var ddlDigitalBankingFH = objData.filter(obj => obj.PartnerRiskClassification == $("#PartnerRiskClassification").text() && obj.APIRiskClassification == $("#APIRiskClassification").text() && obj.ApproverType == "Digital Banking" && obj.ApproverLevel == "FH")
                if (ddlDigitalBankingFH.length > 0) {
                    $.each(ddlDigitalBankingFH, function (data, value) {
                        $("#ddlDigitalBankingFH").append($("<option></option>").val(value.ApproverUserID).html(value.ApproverName));
                    });
                }
                else {
                    $("#ddlDigitalBankingFH").hide();
                }

                /*Bind OPtion ddlDigitalBankingVH */
                var ddlDigitalBankingVH = objData.filter(obj => obj.PartnerRiskClassification == $("#PartnerRiskClassification").text() && obj.APIRiskClassification == $("#APIRiskClassification").text() && obj.ApproverType == "Digital Banking" && obj.ApproverLevel == "VH")
                if (ddlDigitalBankingVH.length > 0) {
                    $.each(ddlDigitalBankingVH, function (data, value) {
                        $("#ddlDigitalBankingVH").append($("<option></option>").val(value.ApproverUserID).html(value.ApproverName));
                    });
                }
                else {
                    $("#ddlDigitalBankingVH").hide();
                }

                /*Bind OPtion ddlISGGH */
                var ddlISGGH = objData.filter(obj => obj.PartnerRiskClassification == $("#PartnerRiskClassification").text() && obj.APIRiskClassification == $("#APIRiskClassification").text() && obj.ApproverType == "ISG" && obj.ApproverLevel == "GH")
                if (ddlISGGH.length > 0) {
                    $.each(ddlISGGH, function (data, value) {
                        $("#ddlISGGH").append($("<option></option>").val(value.ApproverUserID).html(value.ApproverName));
                    });
                }
                else {
                    $("#ddlISGGH").hide();
