<script src="~/js/jquery.min.js"></script>
<script src="~/js/Common.js"></script>
<script>
    $(document).ready(function () {
        //debugger
        $("#btnproceed").click(function () {
            if ($('input[name="diagnose"]:checked').length == 0) {
                $("#btnprocess_Span").text('Please select the Diagnose UAT Issue options!!!');
                $("#btnprocess_Span").show();
                return false;
            }
            else {
                $("#btnprocess_Span").hide();
                return true;
            }
        });
    });
</script>

