@using API_Adda.Models
@model API_Adda.Models.SearchAPI;
@{
    ViewData["Title"] = "apiDetails";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

@using (Html.BeginForm("apiDetails", "Home", FormMethod.Post))
{
    <div class="container mt-10">
        <div class="card">
            <div class="card-body">
                <div class="row form-group">
                    <div class="col-md-12 addnew-popup-heading" style="border-bottom: 1px solid #f5eeee;">
                        <h4>API Details</h4>

                        <a href="@Url.Action("search", "home")" data-form-method="post" class="close-btn" style="font-size: 15px; font-weight: 600;"><i class="bx bx-left-arrow-circle" style="vertical-align:middle;"></i> Back</a>
                        @*<a href="@Url.Action("search", "home")" data-form-method="post"> <i class="bx bx-left-arrow-circle" style="vertical-align:middle;"></i> Back</a>
                    <button>back</button>*@

                    </div>
                </div>
                <div class="row">
                    <div class="col-md-9">
                        <span class="method-tag badge rounded-pill text-bg-success">Post</span><span id="urltext" class="url-details">
                            @Html.DisplayFor(x => x.ServiceUrl)
                            @Html.HiddenFor(x => x.ServiceUrl)
                            @Html.HiddenFor(x => x.SearchAPIURL)
                            @Html.HiddenFor(x => x.APIMainId)
                            @Html.HiddenFor(x => x.lstConsumer)
                            @Html.HiddenFor(x => x.lstMiddlewares)
                            @Html.HiddenFor(x => x.lstProducer)
                            @Html.HiddenFor(x => x.lstServiceProviders)
                        </span>
                    </div>
                    <div class="col-md-3 text-right">
                        <a class="has-arrow" href="/Home/Test"></a>
                        <input type="submit" class="btn btn-primary" name="button" value="Test API" />
                        @*<button id="Test" type="submit" class="btn btn-primary"  value="Test">Test</button>*@
                        @*<button type="button" class="btn btn-primary">Demo</button>*@
                    </div>
                </div>
                <div class="section form-group">
                    <div class="heading" style="margin-top: 2%;">
                        <h4>Overview</h4>
                    </div>
                    <p id="serviceDesc">
                        @Html.DisplayFor(x => x.ServiceDesc)
                        @Html.HiddenFor(x => x.ServiceDesc)
                    </p>
                </div>
                <div class="wrapper form-group">
                    <div class="section">
                        <div class="heading">
                            <h4>Request</h4>
                        </div>

                        @Html.TextAreaFor(x => x.Raw, new { @class = "form-control", @rows = 10 })
                    </div>
                </div>
                <div class="wrapper form-group">
                    <div class="section">
                        <div class="heading">
                            <h4>Response</h4>
                        </div>


                        @Html.TextAreaFor(x => x.response, new { @class = "form-control", @rows = 10 })


                    </div>
                </div>
