                <div class="wrapper form-group">
                    <label class="label-control">Service Document</label>&nbsp; &nbsp;
                    <a class="btn btn-primary" id="btn_DownloadServiceDocument" style="display:inline-block;padding: 0px 4px;margin-top:5px"><i class="bx bx-cloud-download" style="font-size: 20px;margin-top:2px;"></i></a>
