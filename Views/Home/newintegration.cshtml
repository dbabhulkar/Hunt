    function checkSpocrowcount() {
        return new Promise(function (resolve, reject) {
            var msg;
            var Appids = APPidvalue;
            $("#tbladdspoc tbody").empty();



            $.ajax({
                type: "POST",
                url: '/Admin/GetAppDetail',
                data: {
                    data: Appids
                },
                dataType: 'json',
                success: function (response) {
                    if (response != null) {
                        var data = response.spocMasterLists;
                        if (data != '' && data != null) {
                            msg = 'spocvalueget';
                        } else {
                            //alert('no spoc available this app, please update spoc first ');
                            msg = 'nospocvalueget';
                        }
                        resolve(msg);
                    } else {
                        toastr.error("Information not available against this Application.");
                        reject("Error: Information not available");
                    }
                },
                error: function (error) {
                    console.error("Error occurred during AJAX request: ", error);
                    reject("Error occurred during AJAX request");
                }
            });
        });
    }

