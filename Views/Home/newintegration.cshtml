    function RulesetPlatform() {

        var ConsumerIN = "";
        var ConsumerOut = "";
        var ProducerIN = "";
        var ProducerOut = "";
        var ConsumerDC = $("#serviceDetails1_ConsumerDC").val();
        var ProducerDC = $("#serviceDetails1_ProducerDC").val();
        //-----------
        if (ConsumerDC != '' && ProducerDC != '') {

            if (ConsumerDC == 'Bank DC' || ConsumerDC == 'Bank Landing Zone') {
                ConsumerIN = "IN";
            }
            if (ProducerDC == 'Bank DC' || ProducerDC == 'Bank Landing Zone') {
                ProducerIN = "IN";
            }
            if (ConsumerDC == 'External' || ProducerDC == 'Bank Landing Zone') {
                ConsumerOut = "OUT";
            }
            if (ProducerDC == 'External') {
                ProducerOut = "OUT";
            }

            if (ConsumerIN == "IN" && ProducerIN == "IN") {
                $("#serviceDetails1_Platform").val('Internal');
            }
            else if (ConsumerIN == "IN" && ProducerOut == "OUT") {
                //$("#serviceDetails1_Platform").val('External');
                $("#serviceDetails1_Platform").val('Internal & External');
            }
            else if (ConsumerOut == "OUT" && ProducerIN == "IN") {
                $("#serviceDetails1_Platform").val('Internal & External');
            }
            else if (ConsumerOut == "OUT" && ProducerOut == "OUT") {
                $("#serviceDetails1_Platform").val('External');
            }

        }
    }


    function Externalservicereadonly() {
