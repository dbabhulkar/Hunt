        }
        else {
            $("#serviceDetails1_ExternalServiceName").prop('readonly', false);
            $("#serviceDetails1_ExternalServiceName").css('background-color', '#fff');
            $('#serviceDetails1_ExternalServiceName').css('color', '#212529');
        }
    }


