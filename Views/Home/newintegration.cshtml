    function openFileInPopup(url) {

        try {
            if (url) {
                var width = 800;
                var height = 600;
                var left = (window.screen.width - width) / 2;
                var top = (window.screen.height - height) / 2;

                fetch(url)
                    .then(function (response) {
                        if (!response.ok) {
                            if (response.status == 404) {
                                alert("No File Uploaded For This");
                            }
                            else {
                                alert("HTTP Error: " + response.status);
                            }
                        } else {
                            var newWindow = window.open(url, '_blank', 'width=' + width + ', height=' + height + ', left=' + left + ', top=' + top);

                            if (newWindow) {
                                newWindow.focus();
                            } else {
                                alert("Failed to open the file. Please check if the file exists.");
                            }
                        }
                    })
                    .catch(function (error) {
                        alert("An error occurred: " + error.message);
                    });
            } else {
                alert("No file uploaded for this.");
            }
        } catch (error) {
            alert("An error occurred: " + error.message);
        }
    }
    function isNumberKey(evt) {
        var charCode = (evt.which) ? evt.which : event.keyCode;
        if (charCode != 46 && charCode > 31
            && (charCode < 48 || charCode > 57))
            return false;

        return true;
    }

