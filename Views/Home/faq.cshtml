    function BindQuestiondetaillist() {
        debugger;
        //var userid = $(this).closest("tr").find(".nr").text();
        var umodel = @Html.Raw(Newtonsoft.Json.JsonConvert.SerializeObject(Model));
        // var inplatform = $('#@Html.IdFor(m => m.IN_Platform)').val();
