    function calculationValidation() {
        var cmbOprationApi = $("#serviceDetails1_OprationApi").val();
        var cmbApiHandle = $("#serviceDetails1_ApiHandle").val();
        var cmbFTransac = $("#serviceDetails1_FinancialTransaction").val();
        var cmbEstimate = $("#serviceDetails1_EstimateValue").val();
        var cmbAvailability = $("#serviceDetails1_Availability").val();
        $('#ValidOprationApi').text('');
        $('#ValidApiHandle').text('');
        $('#ValidFTrasac').text('');
        $('#ValidEstimateValue').text('');
        $('#ValidAvailability').text('');
        if (cmbOprationApi == 0) {
            $("#ValidOprationApi").text('Selection Required');
            $("#ValidOprationApi").show();
            return false;
        }
        else if (cmbApiHandle == 0) {
            $("#ValidApiHandle").text('Selection Required');
            $("#ValidApiHandle").show();
            return false;
        }
        else if (cmbFTransac == 0) {
            $("#ValidFTrasac").text('Selection Required');
            $("#ValidFTrasac").show();
            return false;
        }
        else if (cmbEstimate == 0) {
            $("#ValidEstimateValue").text('Selection Required');
            $("#ValidEstimateValue").show();
            return false;
        }
        else if (cmbAvailability == 0) {
            $("#ValidAvailability").text('Selection Required');
            $("#ValidAvailability").show();
            return false;
        }
        else {
            return true;
        }
    }
