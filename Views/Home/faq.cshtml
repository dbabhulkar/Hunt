            Address: $('#@Html.IdFor(m=>m.customer.Address)').val()
            }*@

          //var integration = {
        //In_platform


            debugger;
        $.ajax({
            type: "POST",
            url: '/home/GetQuestonDetail',
            data: {
                umodel: umodel

            },
            dataType: 'json',
            success: function (response) {
                debugger
                if (response != null) {
                    //alert(1);
                    /* bind dynamic question start*/
                    //console.log(response);
                    $('#newQueTest').empty();

                    var APICategory = $("#serviceDetails1_APICategory_Id option:selected").text();
                    var Qtype = $("#serviceDetails1_Platform").val();

                    var startDiv = `<div class="row form-group">`;
                    var endDiv = `</div>`;

                    var filteredQuestions = response.questionList.filter(obj => obj.qType == Qtype && obj.apiCategory == APICategory);
                    var rowCount = 0;

                    filteredQuestions.forEach(question => {
                        debugger;
                        var questionText = `<div class="col-md-6"><label class="label-control"><label>${question.question}</label><span style="font-weight:bold;color:red;font-size: 12px;">    *</span></label>`;

                        var hiddenFields = `<input type="hidden" name="id" value="${question.id}">
                              <input type="hidden" name="qType" value="${question.qType}">
                              <input type="hidden" name="apiCategory" value="${question.apiCategory}">
                              <input type="hidden" name="apiCategoryId" value="${question.apiCategoryId}">
                              </div>`;

                        var qValueDropList = response.qDropValuesList.filter(qValue => qValue.qid == question.id);

                        var dropdown = qValueDropList.length > 0
                            ? `<div class="col-md-3"><select class="form-control QdropValue" name="dropdown" id="QuestinonselectedList_${rowCount}__Weightage_1">
                                ${qValueDropList.map(qValue => `<option value="${qValue.id}">${qValue.val}</option>`).join('')}
                                </select></div>
                                <div class="col-md-3"><span id="'QdropValue_' " style="display:none;font-weight:bold;color:red;font-size: 12px;"></span></div>`
                            : '';

                        $('#newQueTest').append(startDiv + questionText + hiddenFields + dropdown + endDiv);
                        rowCount++;
                    });
                    /* bind dynamic question end*/
                }
                else {
                    toastr.error("no question detail get");
                }
            }
        });
    };

