    function setPlatform(val) {

        var ConsumerIN = "";
        var ConsumerOut = "";
        var ProducerIN = "";
        var ProducerOut = "";
        var ConsumerDC_Id = $("#serviceDetails1_ConsumerDC_Id").val();
        var ProducerDC_Id = $("#serviceDetails1_ProducerDC_Id").val();

        //-----------
        if (ConsumerDC_Id == 46 || ConsumerDC_Id == 47) {
            ConsumerIN = "IN";
        }
        if (ProducerDC_Id == 49 || ProducerDC_Id == 50) {
            ProducerIN = "IN";
        }
        if (ConsumerDC_Id == 48 || ProducerDC_Id == 50) {
            ConsumerOut = "OUT";
        }
        if (ProducerDC_Id == 51) {
            ProducerOut = "OUT";
        }

        if (ConsumerIN == "IN" && ProducerIN == "IN") {
            $("#serviceDetails1_Platform").val('Internal');
        }
        else if (ConsumerIN == "IN" && ProducerOut == "OUT") {
            $("#serviceDetails1_Platform").val('External');
        }
        else if (ConsumerOut == "OUT" && ProducerIN == "IN") {
            $("#serviceDetails1_Platform").val('Internal & External');
        }
        else if (ConsumerOut == "OUT" && ProducerOut == "OUT") {
            $("#serviceDetails1_Platform").val('External ');
        }

    }







