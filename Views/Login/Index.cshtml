@model API_HUNT.Models.LoginModel
@{
    Layout = null;
}

<!DOCTYPE html>

<html>
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Login - API HUNT</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://unpkg.com/boxicons@2.1.4/css/boxicons.min.css" rel="stylesheet" />
    <link href="~/css/style.css" rel="stylesheet" />
</head>
<body style="background: #fff;">
    <div class="login-wrapper">
        <!-- Left — Brand panel -->
        <div class="login-brand">
            <div>
                <div class="brand-name">API HUNT</div>
                <div class="app-chip">Partner Integration Platform</div>
            </div>
            <div>
                <div class="tagline">
                    One platform for API discovery, testing and partner integration.
                </div>
                <div class="tagline-sub">
                    For development teams and integration partners. Manage onboarding, testing, and exceptions in one place.
                </div>
            </div>
            <div class="version-info">
                3i Infotech · For internal use only
            </div>
        </div>

        <!-- Right — Login form -->
        <div class="login-form-panel">
            @using (Html.BeginForm("Index", "Login", FormMethod.Post, new { @enctype = "multipart/form-data" }))
            {
                <div class="login-form">
                    <div>
                        <h2 class="login-heading">Sign in</h2>
                        <p class="login-sub">Enter your credentials to continue</p>
                    </div>

                    <div class="form-group">
                        @Html.LabelFor(a => a.UserId, new { @class = "label-control" })
                        <div class="input-group">
                            @Html.TextBoxFor(a => a.UserId, new { @class = "form-control", autofocus = "", placeholder = "Enter User ID" })
                            <div class="input-group-addon">
                                <i class="bx bx-user"></i>
                            </div>
                        </div>
                        @Html.ValidationMessageFor(a => a.UserId)
                    </div>

                    <div class="form-group">
                        @Html.LabelFor(a => a.Password, new { @class = "label-control" })
                        <div class="input-group">
                            @Html.TextBoxFor(a => a.Password, new { @class = "form-control", Type = "Password", placeholder = "Enter Password" })
                            <div class="input-group-addon">
                                <i class="bx bxs-lock"></i>
                            </div>
                        </div>
                        @Html.ValidationMessageFor(a => a.Password)
                    </div>

                    <div class="login-actions">
                        <label>
                            <input type="checkbox" /> Remember me
                        </label>
                        <a href="#">Forgot password?</a>
                    </div>

                    <input type="submit" class="btn btn-primary" name="button" id="BtnLogin" value="Sign in" />

                    @if (TempData["Message"] != null)
                    {
                        <div class="login-error">@TempData["Message"]</div>
                    }
                </div>
            }
        </div>
    </div>

    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery/3.7.1/jquery.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
