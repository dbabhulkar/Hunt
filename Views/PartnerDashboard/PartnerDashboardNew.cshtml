@using Microsoft.AspNetCore.Http
@inject IHttpContextAccessor Accessor
@{
    ViewData["Title"] = "Partner Dashboard";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container-fluid">
    <div class="ovi-card" style="margin-bottom: 22px;">
        <div class="ovi-card-header">
            <h4 class="card-title">Partner Dashboard</h4>
            <a href="/home/index/" class="close-btn"><i class="bx bx-left-arrow-circle" style="vertical-align:middle;"></i> Back</a>
        </div>
    </div>

    <!-- Stat tiles row -->
    <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 14px; margin-bottom: 22px;">
        @if (Accessor.HttpContext.Session.GetString("Role") == "USER" || Accessor.HttpContext.Session.GetString("Role") == "ADMIN")
        {
            <a href="/PartnerOnboarding/ListofPartner" style="text-decoration: none;">
                <div class="stat-tile" style="background: var(--ovi-gradient-11); cursor: pointer;">
                    <div class="stat-label">Partner Onboarding</div>
                    <div>
                        <div class="stat-value"><i class="bx bx-user-circle" style="font-size: 28px;"></i></div>
                        <div class="stat-sub">Onboarding Partner with Partner Risk</div>
                    </div>
                </div>
            </a>
        }

        <a href="/Partner_Integration/ListofPartnerIntegration" style="text-decoration: none;">
            <div class="stat-tile" style="background: var(--ovi-gradient-14); cursor: pointer;">
                <div class="stat-label">Partner Integration</div>
                <div>
                    <div class="stat-value"><i class="bx bx-code-alt" style="font-size: 28px;"></i></div>
                    <div class="stat-sub">Access to APIs with Approval Workflow</div>
                </div>
            </div>
        </a>

        @if (Accessor.HttpContext.Session.GetString("Role") != "USER")
        {
            <a href="/PartnerOffboarding/PartnerOffboarding" style="text-decoration: none;">
                <div class="stat-tile" style="background: var(--ovi-gradient-16); cursor: pointer;">
                    <div class="stat-label">Partner Offboarding</div>
                    <div>
                        <div class="stat-value"><i class="bx bx-log-out-circle" style="font-size: 28px;"></i></div>
                        <div class="stat-sub">Offboard Partners from APIs</div>
                    </div>
                </div>
            </a>
        }

        @if (Accessor.HttpContext.Session.GetString("Role") == "APPROVER" || Accessor.HttpContext.Session.GetString("Role") == "ADMIN")
        {
            <a href="/PartnerApproval/ListofPartner/" style="text-decoration: none;">
                <div class="stat-tile" style="background: var(--ovi-gradient-1); cursor: pointer;">
                    <div class="stat-label">Partner Approval</div>
                    <div>
                        <div class="stat-value"><i class="bx bx-check-shield" style="font-size: 28px;"></i></div>
                        <div class="stat-sub">Approve partner requests</div>
                    </div>
                </div>
            </a>
        }
    </div>

    <!-- Quick links card -->
    <div class="ovi-card">
        <div class="ovi-card-header">
            <h4 class="card-title">Quick Links</h4>
        </div>
        <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(250px, 1fr)); gap: 10px;">
            <a href="/home/search/" style="text-decoration: none;">
                <div style="padding: 12px 16px; border: 1px solid var(--ovi-border-card); border-radius: var(--ovi-r-md); display: flex; align-items: center; justify-content: space-between; color: var(--ovi-brand-blue); font-size: 13px; transition: background .15s;">
                    Search API
                    <i class="fa fa-chevron-right" style="font-size: 11px; color: var(--ovi-text-muted);"></i>
                </div>
            </a>
            <a href="/home/TestAPI/" style="text-decoration: none;">
                <div style="padding: 12px 16px; border: 1px solid var(--ovi-border-card); border-radius: var(--ovi-r-md); display: flex; align-items: center; justify-content: space-between; color: var(--ovi-brand-blue); font-size: 13px; transition: background .15s;">
                    Test API
                    <i class="fa fa-chevron-right" style="font-size: 11px; color: var(--ovi-text-muted);"></i>
                </div>
            </a>
            <a href="/home/NewIntegrationList/" style="text-decoration: none;">
                <div style="padding: 12px 16px; border: 1px solid var(--ovi-border-card); border-radius: var(--ovi-r-md); display: flex; align-items: center; justify-content: space-between; color: var(--ovi-brand-blue); font-size: 13px; transition: background .15s;">
                    New Integration
                    <i class="fa fa-chevron-right" style="font-size: 11px; color: var(--ovi-text-muted);"></i>
                </div>
            </a>
            <a href="/home/faq/" style="text-decoration: none;">
                <div style="padding: 12px 16px; border: 1px solid var(--ovi-border-card); border-radius: var(--ovi-r-md); display: flex; align-items: center; justify-content: space-between; color: var(--ovi-brand-blue); font-size: 13px; transition: background .15s;">
                    FAQ
                    <i class="fa fa-chevron-right" style="font-size: 11px; color: var(--ovi-text-muted);"></i>
                </div>
            </a>
        </div>
    </div>
</div>
