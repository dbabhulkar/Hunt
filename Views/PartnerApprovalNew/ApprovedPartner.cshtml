                                                                <td style="width: 170px; text-align: center;" class="d-none">
                                                                    <!-- Button only in the last iteration --><!-- Button only in the last iteration -->
                                                                    <button class="close-btn" type="button" onclick="removeAPIRow(this)" style="margin-right: 115px;font-size: 10px;"><i class="bx bx-x-circle" style="color: red;"></i></button>
                                                                    <button id="btnViewAPIRisk" name="btnViewAPIRisk" class="action-button btn btn-primary btn-sm d-none" style="border-radius: 3px;margin-top: 0px; background-color: #3498db; color: #fff; border: none; cursor: pointer; transition: background-color 0.3s ease; font-size: 10px;" onclick="openFileInPopup('@Url.Action("DisplayFile", "PartnerIntegrationNew" , new { fileName=Model.CaseID + "_APIRiskAssessment" })')">VIEW API RISK SCORE</button>
                                                                </td>
