                                        @Html.TextBoxFor(a => a.PartnerSubType, new { @class = "form-control", @readonly = "readonly", @style = "background-color: lightgray;" })
                                        @Html.ValidationMessageFor(a => a.PartnerSubType, "", new { @class = "text-danger" })
                                        @Html.HiddenFor(a => a.PartnerSubType, new { @class = "form-control", @id = "hdnPartnerSubType" })
                                    </div>
                                    <div class="col-md-4">
                                        @Html.LabelFor(a => a.PartnerEntityType, new { @class = "label-control" })&nbsp;&nbsp;<span style="font-weight:bold;color:red;font-size: 12px;">*</span>
                                        @Html.TextBoxFor(a => a.PartnerEntityType, new { @class = "form-control", @readonly = "readonly", @style = "background-color: lightgray;" })
                                        @Html.ValidationMessageFor(a => a.PartnerEntityType, "", new { @class = "text-danger" })
                                        @Html.HiddenFor(a => a.PartnerEntityType, new { @class = "form-control", @id = "hdnPartnerEntityType" })
