                                                                    <i class="bx bxs-show" style="font-size:20px;"></i> <!-- Display icon -->
                                                                </a>
                                                                @*@if (Model.status == "Created")
                                                    {
                                                    <span>|</span>
                                                    <label for="AttachedJourneyDocuments" class="upload">
                                                    <i class="bx bx-cloud-upload" style="font-size: 20px;margin-top:2px;color: #5777ba;"></i>
                                                    <input name="AttachedJourneyDocuments" id="AttachedJourneyDocuments" type="file" class="file-upload-field" value="" accept=".zip,.7z,.doc,.xls,.xlsx,.pdf" style="display: none;">
                                                    </label>
                                                    <span id="spnAttachedJourneyDocuments" class="label-control" style="color:grey;"></span>
                                                    }*@
                                                            }
                                                            else
                                                            {
                                                                <span class="text-danger">Not Uploaded</span>
                                                            }
                                                        </td>
                                                    </tr>
