                                                        <td class="d-none">
                                                            <button class="close-btn" type="button" onclick="removeAPIRow(this)"><i class="bx bx-x-circle" style="color: red;"></i></button>
                                                        </td>
                                                        @if (Model.status == "Created")
                                                        {
                                                            @if (i == Model.lstApiDeatil.Count - 1)
