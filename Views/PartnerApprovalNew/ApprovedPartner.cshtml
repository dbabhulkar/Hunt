@model API_Adda.Models.PartnerApprovalNew
@inject IHttpContextAccessor Accessor
@using Microsoft.AspNetCore.Http
@{
    ViewData["Title"] = "ApprovedPartner";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

@using (Html.BeginForm("SaveAddPartneronBoarding", "PartnerApprovalNew", FormMethod.Post, new { @enctype = "multipart/form-data" }))
{
    <div class="container mt-10">
        <div class="card">
            <div class="card-body">
                <div class="row form-group">
                    <div class="col-md-12 addnew-popup-heading" style="border-bottom: 1px solid #f5eeee;">
                        <h4>Approve Partner</h4>
                        <a href="/PartnerApprovalNew/ListofPartner/" class="close-btn" style="font-size: 15px; font-weight: 600;"><i class="bx bx-left-arrow-circle" style="vertical-align:middle;"></i> Back</a>
                    </div>
                </div>
                <div class="row form-group">
                    <div id="msform">
                        <ul id="progressbar">
                            <li class="active" id="onboarding"><strong>Partner Onboarding</strong></li>
                            <li id="approval"><strong>Sent For Approval</strong></li>
                        </ul>
                        <fieldset>
                            <section class="background">
                                <b>Partner Details:</b>
                                <div class="row form-group">
                                    <div class="col-md-4">
                                        @Html.LabelFor(a => a.PartnerName, new { @class = "label-control" })&nbsp;&nbsp;<span style="font-weight:bold;color:red;font-size: 12px;">*</span>
                                        @Html.TextBoxFor(a => a.PartnerName, new { @class = "form-control", @readonly = "readonly", @style = "background-color: lightgray;" })
                                        @Html.ValidationMessageFor(a => a.PartnerName, "", new { @class = "text-danger" })
                                        @Html.HiddenFor(a => a.PartnerID)
                                        @Html.HiddenFor(a => a.CaseID)
                                        @Html.HiddenFor(a => a.Action)

                                        @Html.HiddenFor(a => a.CurrentApproverLevel, new { @class = "form-control" })
                                        @Html.HiddenFor(a => a.CurrentApproverUserID, new { @class = "form-control" })
                                        @Html.HiddenFor(a => a.CurrentSequence, new { @class = "form-control" })
                                        @Html.HiddenFor(a => a.CurrentDepartment, new { @class = "form-control" })
                                        @Html.HiddenFor(a => a.CurrentApprovalTrialID, new { @class = "form-control" })
                                        @Html.HiddenFor(a => a.PartnerSubType, new { @class = "form-control" })
                                    </div>
                                    <div class="col-md-4">
                                        @Html.LabelFor(a => a.PartnerDescription, new { @class = "label-control" })&nbsp;&nbsp;
