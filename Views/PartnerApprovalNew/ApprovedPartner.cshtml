                                                                    <!-- Button only in the last iteration -->
                                                                    <button class="close-btn" type="button" onclick="removeAPIRow(this)" style="margin-right: 115px;font-size: 10px;"><i class="bx bx-x-circle" style="color: red;"></i></button>
                                                                </td>
                                                            }
                                                        }
                                                    </tr>
                                                }
                                            </tbody>
                                        </table>
                                    </div>
                                </div>
