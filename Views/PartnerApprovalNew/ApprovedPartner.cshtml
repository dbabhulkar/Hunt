                                                        </td>
                                                        <td class="APIRisktd">
                                                            <input type="text" name="APIRisk_@i" id="APIRisk_@i" class="form-control APIRisk" readonly style="background-color: lightgray;" value="@Model.lstApiDeatil[i].APIRisk" />
                                                        </td>
                                                        <td>
                                                            <input type="text" name="APIRiskScore_@i" id="APIRiskScore_@i" class="form-control APIRiskScore" readonly style="background-color: lightgray;" value="@Model.lstApiDeatil[i].APIRiskScore" />
