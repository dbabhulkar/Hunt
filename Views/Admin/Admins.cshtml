            $('#HostingDC').on("input", function () {
                var appShortName = $('#APPShortName').val();
                var hostingDCValue = $('#HostingDC').val(); // Get the current value of HostingDC dropdown

                if (hostingDCValue === "External" && (appShortName == null || appShortName.trim() === "")) {
                    alert("Please enter Application Short Name first !!!");
                    $('#HostingDC').val($('#HostingDC option:first').val()); // Set HostingDC to its first value
                    $('#HostingDC').trigger('change'); // Trigger change event to ensure other associated actions are performed
                }
                else if (hostingDCValue === "External") {
                    $('#ITGRCCode').val('EXTERNAL-' + appShortName);
                    $('#ITGRCName').val(appShortName);
                    $('#ITGRCCode').prop("disabled", true); // Disable editing when HostingDC is External
                    $('#ITGRCName').prop("disabled", true); // Disable editing when ITGRCName is External
                } else if (hostingDCValue === "Bank DC" || hostingDCValue === "Bank Landing Zone") {
                    $('#ITGRCCode').val('APPID-');
                    $('#ITGRCName').val('');
                    $('#ITGRCCode').prop("disabled", false);
                    $('#ITGRCName').prop("disabled", false);
                } else {
                    $('#ITGRCCode').val('');
                    $('#ITGRCName').val('');
                    $('#ITGRCCode').prop("disabled", false); // Enable editing when HostingDC is not External
                    $('#ITGRCName').prop("disabled", false); // Enable editing when HostingDC is not External
                }
            });
